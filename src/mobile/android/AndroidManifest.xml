<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.darktable.mobile"
    android:versionCode="1"
    android:versionName="0.1.0"
    android:installLocation="auto">

    <!-- Network access for P2P peer communication -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Keep the daemon alive while the app is active -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Camera for QR code scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera"
                  android:required="false" />

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:label="Darktable Mobile"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="false"
        android:allowBackup="false">

        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:label="Darktable Mobile"
            android:screenOrientation="unspecified"
            android:launchMode="singleTop"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density"
            android:exported="true">

            <!-- Standard launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- darktable://pair?d=BASE64 deep link from QR codes or shared links -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="darktable" android:host="pair" />
            </intent-filter>

            <!-- Qt 6 only needs lib_name; array resources are Qt5-era and not used here -->
            <meta-data android:name="android.app.lib_name"
                       android:value="darktable-mobile" />
            <meta-data android:name="android.app.extract_android_style"
                       android:value="minimal" />
        </activity>

    </application>
</manifest>
