msgstr "4 bilder på US Letter papir"

#: ../build/bin/styles_string.h:4
msgid "add simulated motion blur to the image"
msgstr "legg til simulert bevegelsesuskarphet på bildet"

#: ../build/bin/styles_string.h:5
