#. Additional parameters
#. Camera settings
#: ../src/iop/diffuse.c:1763 ../src/iop/splittoning.c:516
#: ../src/libs/camera.c:509
msgctxt "section"
msgid "properties"
msgstr "egenskaper"

#: ../src/iop/diffuse.c:1769
msgid ""
"more iterations make the effect stronger but the module slower.\n"
"this is analogous to giving more time to the diffusion reaction.\n"
"if you plan on sharpening or inpainting, \n"
"more iterations help reconstruction."
msgstr ""
"flere gjentakelser gjør effekten sterkere men modulen blir tregere.\n"
"dette tilsvarer å gi mer tid til diffusjonsreaksjonen.\n"
"hvis du tenker å skjerpe eller male inn\n"
"vil flere gjentakelser hjelpe rekonstruksjonen."

#: ../src/iop/diffuse.c:1778
msgid ""
"main scale of the diffusion.\n"
"zero makes diffusion act on the finest details more heavily.\n"
"non-zero defines the size of the details to diffuse heavily.\n"
"for deblurring and denoising, set to zero.\n"
"increase to act on local contrast instead."
msgstr ""
"hovedskala for diffusjonen.\n"
"null lar diffusjonen virke mer på de minste detaljene.\n"
"annet enn null angir størrelsen på detaljene som skal diffuseres mest.\n"
"for å fjerne uskarphet og støy, sett til null.\n"
"øk for å virke på lokal kontrast i stedet."

#: ../src/iop/diffuse.c:1788
msgid ""
"width of the diffusion around the central radius.\n"
"high values diffuse on a large band of radii.\n"
"low values diffuse closer to the central radius.\n"
"if you plan on deblurring, \n"
"the radius should be around the width of your lens blur."
msgstr ""
"diffusjonens vidde rundt den sentrale radien.\n"
"høye verdier diffuserer mange radier.\n"
"lave verdier diffuserer nærmere den sentrale radien.\n"
"hvis du vil fjerne uskarphet\n"
"bør radien være rundt vidden av linseuskarpheten."

#: ../src/iop/diffuse.c:1794
msgctxt "section"
msgid "speed (sharpen ↔ diffuse)"
msgstr "hastighet (skjerpe ↔ diffusering)"

#: ../src/iop/diffuse.c:1800
msgid ""
"diffusion speed of low-frequency wavelet layers\n"
"in the direction of 1st order anisotropy (set below).\n"
"\n"
"negative values sharpen, \n"
"positive values diffuse and blur, \n"
"zero does nothing."
msgstr ""
"diffuseringshastighet for lavfrekvente småbølelag\n"
"i retningen av 1. ordens anisotropi (angitt under).\n"
"\n"
"negative verdier skjerper,\n"
"positive verdier diffuserer og gjør uskarpt,\n"
"null gjør ikke noe."

#: ../src/iop/diffuse.c:1810
msgid ""
"diffusion speed of low-frequency wavelet layers\n"
"in the direction of 2nd order anisotropy (set below).\n"
"\n"
"negative values sharpen, \n"
"positive values diffuse and blur, \n"
"zero does nothing."
msgstr ""
"diffuseringshastighet for lavfrekvente småbølelag\n"
"i retningen av 2. ordens anisotropi (angitt under).\n"
"\n"
"negative verdier skjerper,\n"
"positive verdier diffuserer og gjør uskarpt,\n"
"null gjør ikke noe."

#: ../src/iop/diffuse.c:1820
msgid ""
"diffusion speed of high-frequency wavelet layers\n"
"in the direction of 3rd order anisotropy (set below).\n"
"\n"
"negative values sharpen, \n"
"positive values diffuse and blur, \n"
"zero does nothing."
msgstr ""
"diffuseringshastighet for høyfrekvente småbølelag\n"
"i retningen av 3. ordens anisotropi (angitt under).\n"
"\n"
"negative verdier skjerper,\n"
"positive verdier diffuserer og gjør uskarpt,\n"
"null gjør ikke noe."

#: ../src/iop/diffuse.c:1830
msgid ""
"diffusion speed of high-frequency wavelet layers\n"
"in the direction of 4th order anisotropy (set below).\n"
"\n"
"negative values sharpen, \n"
"positive values diffuse and blur, \n"
"zero does nothing."
msgstr ""
"diffuseringshastighet for høyfrekvente småbølelag\n"
"i retningen av 4. ordens anisotropi (angitt under).\n"
"\n"
"negative verdier skjerper,\n"
"positive verdier diffuserer og gjør uskarpt,\n"
"null gjør ikke noe."

#: ../src/iop/diffuse.c:1836
msgctxt "section"
msgid "direction"
msgstr "retning"

#: ../src/iop/diffuse.c:1842
msgid ""
"direction of 1st order speed (set above).\n"
"\n"
"negative values follow gradients more closely, \n"
"positive values rather avoid edges (isophotes), \n"
"zero affects both equally (isotropic)."
msgstr ""
"retning for 1. ordens hastighet (angitt over).\n"
"\n"
"negative verdier følger gradienter nærmere,\n"
"positive verdier unngår kanter (isofoter),\n"
"null påvirker begge like mye (isotropisk)."

#: ../src/iop/diffuse.c:1851
msgid ""
"direction of 2nd order speed (set above).\n"
"\n"
"negative values follow gradients more closely, \n"
"positive values rather avoid edges (isophotes), \n"
"zero affects both equally (isotropic)."
msgstr ""
"retning for 2. ordens hastighet (angitt over).\n"
"\n"
"negative verdier følger gradienter nærmere,\n"
"positive verdier unngår kanter (isofoter),\n"
"null påvirker begge like mye (isotropisk)."

#: ../src/iop/diffuse.c:1860
msgid ""
"direction of 3rd order speed (set above).\n"
"\n"
"negative values follow gradients more closely, \n"
"positive values rather avoid edges (isophotes), \n"
"zero affects both equally (isotropic)."
msgstr ""
"retning for 3. ordens hastighet (angitt over).\n"
"\n"
"negative verdier følger gradienter nærmere,\n"
"positive verdier unngår kanter (isofoter),\n"
"null påvirker begge like mye (isotropisk)."

#: ../src/iop/diffuse.c:1869
msgid ""
"direction of 4th order speed (set above).\n"
"\n"
"negative values follow gradients more closely, \n"
"positive values rather avoid edges (isophotes), \n"
"zero affects both equally (isotropic)."
msgstr ""
"retning for 4. ordens hastighet (angitt over).\n"
"\n"
"negative verdier følger gradienter nærmere,\n"
"positive verdier unngår kanter (isofoter),\n"
"null påvirker begge like mye (isotropisk)."

#: ../src/iop/diffuse.c:1874
msgctxt "section"
msgid "edge management"
msgstr "kantbehandling"

#: ../src/iop/diffuse.c:1882
msgid ""
"increase or decrease the sharpness of the highest frequencies.\n"
"can be used to keep details after blooming,\n"
"for standalone sharpening set speed to negative values."
msgstr ""
"øk eller reduser skarpheten til de høyeste frekvensene.\n"
"kan brukes til å beholde detaljer etter gløding,\n"
"for skjerping alene, sett hastighet til negative verdier."

#: ../src/iop/diffuse.c:1889
msgid ""
"define the sensitivity of the variance penalty for edges.\n"
"increase to exclude more edges from diffusion,\n"
"if fringes or halos appear."
msgstr ""
"definer følsomheten til variansestraffen for kanter.\n"
"øk for å utelate flere kanter fra diffusjon,\n"
"hvis fargekanter eller glorier oppstår."

#: ../src/iop/diffuse.c:1896
msgid ""
"define the variance threshold between edge amplification and penalty.\n"
"decrease if you want pixels on smooth surfaces get a boost,\n"
"increase if you see noise appear on smooth surfaces or\n"
"if dark areas seem oversharpened compared to bright areas."
msgstr ""
"angi variansegrensen mellom kantforsterkning og straff.\n"
"reduser hvis du vil at piksler på jevne flater skal forsterkes,\n"
"øk hvis du ser at det oppstår støy på jevne flater eller\n"
"hvis mørke områder virker overskjerpet sammenlignet med lyse områder."

#: ../src/iop/diffuse.c:1901
msgctxt "section"
msgid "diffusion spatiality"
msgstr "utstrekning av diffusjon"

#: ../src/iop/diffuse.c:1907
msgid ""
"luminance threshold for the mask.\n"
"0. disables the luminance masking and applies the module on the whole image.\n"
"any higher value excludes pixels with luminance lower than the threshold.\n"
"this can be used to inpaint highlights."
msgstr ""
"luminansgrense for masken.\n"
"0 deaktiverer luminansemasken og påfører modulen på hele bildet.\n"
"alle høyere verdier utelater piksler med luminans lavere enn grenseverdien.\n"
"dette kan brukes til å male inn høylys."

#: ../src/iop/dither.c:104
msgid "dither or posterize"
msgstr "jevn ut eller posteriser"

#: ../src/iop/dither.c:109
msgid "dithering|posterization|reduce bit depth"
msgstr "utjevning|posterisering|redusere bitdybde"

#: ../src/iop/dither.c:114
msgid ""
"reduce banding and posterization effects in output\n"
"JPEGs by adding random noise, or reduce bit depth"
msgstr ""
"redusere banding og posterisering i JPEG-bilder\n"
"ved å legge til tilfeldig støy eller redusere bitdybde"

#: ../src/iop/dither.c:116
msgid "corrective, artistic"
msgstr "korrigerende, kunstnerisk"

#. add the preset.
#: ../src/iop/dither.c:174
msgid "dither"
msgstr "utjevning"

#: ../src/iop/dither.c:738
msgid "damping level of random dither"
msgstr "dempningsnivå for tilfeldig støy"

#: ../src/iop/enlargecanvas.c:72
msgid "enlarge canvas"
msgstr "forstørre lerret"

#: ../src/iop/enlargecanvas.c:79
msgid "add empty space to the left, top, right or bottom"
msgstr "legg til tomt rom til høyre, venstre, øverst eller nederst"

#: ../src/iop/enlargecanvas.c:88
msgid "composition|expand|extend"
msgstr "komposisjon|forstørr|utvid"

#: ../src/iop/enlargecanvas.c:422
msgid ""
"how much to enlarge the canvas to the left as a percentage of the original "
"image width"
msgstr ""
"hvor mye lerretet skal utvides til venstre som en prosent av den originale "
"bildebredden"

#: ../src/iop/enlargecanvas.c:428
msgid ""
"how much to enlarge the canvas to the right as a percentage of the original "
"image width"
msgstr ""
"hvor mye lerretet skal utvides til høyre som en prosent av den originale "
"bildebredden"

#: ../src/iop/enlargecanvas.c:434
msgid ""
"how much to enlarge the canvas to the top as a percentage of the original "
"image height"
msgstr ""
"hvor mye lerretet skal utvides i toppen som en prosent av den originale "
"bildehøyden"

#: ../src/iop/enlargecanvas.c:440
msgid ""
"how much to enlarge the canvas to the bottom as a percentage of the original "
"image height"
msgstr ""
"hvor mye lerretet skal utvides i bunnen som en prosent av den originale "
"bildehøyden"

#: ../src/iop/enlargecanvas.c:444
msgid "select the color of the enlarged canvas"
msgstr "velg farge for det utvidede lerretet"

#: ../src/iop/equalizer.c:86
msgid "legacy equalizer"
msgstr "gammeldags utligner"

#: ../src/iop/equalizer.c:109
msgid "this module is deprecated. better use contrast equalizer module instead."
msgstr "denne modulen er utdatert. vennligst bruk kontrastutligner i stedet."

#: ../src/iop/equalizer.c:236
msgid ""
"this module will be removed in the future\n"
"and is only here so you can switch it off\n"
"and move to the new equalizer."
msgstr ""
"denne modulen vil bli fjernet i framtiden\n"
"og er her kun for at du skal kunne skru den av\n"
"og bytte til den nye utligneren."

#: ../src/iop/exposure.c:128
msgid ""
"redo the exposure of the shot as if you were still in-camera\n"
"using a color-safe brightening similar to increasing ISO setting"
msgstr ""
"gjør om eksponeringen av bildet som om du fortsatt var i kamera\n"
"ved å bruke en fargesikker lysning tilsvarende å øke ISO-verdien"

#: ../src/iop/exposure.c:315
msgid "magic lantern defaults"
msgstr "magic lantern standardverdier"

#: ../src/iop/exposure.c:388 ../src/iop/rawoverexposed.c:133
#: ../src/iop/rawoverexposed.c:244
#, c-format
msgid "failed to get raw buffer from image `%s'"
msgstr "kunne ikke hente raw-data fra bilde `%s'"

#: ../src/iop/exposure.c:687
#, c-format
msgid "compensate camera exposure (%+.1f EV)"
msgstr "kompenser kameraeksponering (%+.1f EV)"

#: ../src/iop/exposure.c:699
#, no-c-format
msgid "highlight preservation mode (%.1f EV)"
msgstr "metode for bevaring av høylys (%.1f EV)"

#. Write report in GUI
#: ../src/iop/exposure.c:894
#, c-format
msgid "L : \t%.1f %%"
msgstr "L : \t%.1f %%"

#: ../src/iop/exposure.c:1034 ../src/libs/history.c:949
#, c-format
msgid "%.2f EV"
msgstr "%.2f EV"

#: ../src/iop/exposure.c:1199
msgid ""
"automatically remove the camera exposure bias\n"
"this is useful if you exposed the image to the right."
msgstr ""
"fjern automatisk eksponeringskompensasjon gjort i kamera\n"
"dette er nyttig hvis du har eksponert mot høyre."

#: ../src/iop/exposure.c:1205
msgid ""
"remove the camera's hidden exposure bias in\n"
"HDR / highlight preservation / dynamic range / HLG tone mode.\n"
"\n"
"when enabled on an image with nonzero bias, tone mapping\n"
"(e.g. sigmoid) is required to avoid blown-out highlights."
msgstr ""
"fjern kameraets skjulte eksponeringskompensasjon i\n"
"HDR / høylysbevaring / dynamisk område / HLG tonemodus.\n"
"\n"
"når aktivert på et bilde med kompensasjon er tonetilpasning\n"
"(f eks sigmoid) påkrevd for å unngå utbrente høylys."

#: ../src/iop/exposure.c:1217
msgid "set the exposure adjustment using the selected area"
msgstr "juster eksponeringen ved å bruke det valgte området"

#: ../src/iop/exposure.c:1228
#, no-c-format
msgid "where in the histogram to meter for deflicking. E.g. 50% is median"
msgstr ""
"hvor i histogrammet måling skal gjøres for fjerning av blink. F. eks. er 50% "
"middelverdi"

#: ../src/iop/exposure.c:1234
msgid ""
"where to place the exposure level for processed pics, EV below overexposure."
msgstr ""
"hvor eksponeringsnivået for bearbeidede bilder skal plasseres, angitt i EV "
"under overeksponering."

#: ../src/iop/exposure.c:1238
msgid "what exposure correction has actually been used"
msgstr "hvilken eksponeringskorreksjon har faktisk blitt brukt"

#: ../src/iop/exposure.c:1244
msgid "computed EC: "
msgstr "beregnet EC: "

#: ../src/iop/exposure.c:1257
msgid ""
"adjust the black level to unclip negative RGB values.\n"
"you should never use it to add more density in blacks!\n"
"if poorly set, it will clip near-black colors out of gamut\n"
"by pushing RGB values into negatives."
msgstr ""
"juster svart-nivå for å fjerne klipping av RGB-verdier.\n"
"ikke bruk dette for å øke tettheten i svarte områder!\n"
"ved feil bruk vil nesten svarte farger klippes ut av synlig område\n"
"ved å endre RGB-verdier til negative."

#: ../src/iop/exposure.c:1267
msgid "area exposure mapping"
msgstr "eksponerings-tilpasning for område"

#: ../src/iop/exposure.c:1273
msgid ""
"define a target brightness, in terms of exposure,\n"
"for a selected region of the image (the control sample),\n"
"which you then match against the same target brightness\n"
"in other images. the control sample can either\n"
"be a critical part of your subject or a non-moving and\n"
"consistently-lit surface over your series of images."
msgstr ""
"angi en ønsket lysstyrke i form av eksponering\n"
"for et valgt område av bildet (kontrollprøven),\n"
"som du så matcher mot den samme lysstyrken i målet\n"
"i andre bilder. kontrollprøven kan enten være\n"
"en viktig del av motivet eller en stillestående og\n"
"konsistent opplyst overflate gjennom bildeserien."

#: ../src/iop/exposure.c:1282
msgid ""
"\"correction\" automatically adjust exposure\n"
"such that the input lightness is mapped to the target.\n"
"\"measure\" simply shows how an input color is mapped by\n"
"the exposure compensation and can be used to define a target."
msgstr ""
"\"korreksjon\" justerer eksponeringen automatisk\n"
"sånn at originial lysstyrke tilpasses målet.\n"
"\"måling\" viser hvordan en original farge tilpasses av\n"
"eksponeringskompensasjonen og kan brukes til å angi et mål."

#: ../src/iop/exposure.c:1300
msgid "L : \tN/A"
msgstr "L : \tN/A"

#: ../src/iop/exposure.c:1310
msgid "the desired target exposure after mapping"
msgstr "den ønskede måleksponeringen etter tilpasning"

#: ../src/iop/filmic.c:174
msgid "this module is deprecated. better use filmic rgb module instead."
msgstr "denne modulen er utdatert. bruk heller filmic rgb."

#: ../src/iop/filmic.c:328
msgid "09 EV (low-key)"
msgstr "09 EV (dunkelt)"

#: ../src/iop/filmic.c:336
msgid "10 EV (indoors)"
msgstr "10 EV (innendørs)"

#: ../src/iop/filmic.c:344
msgid "11 EV (dim outdoors)"
msgstr "11 EV (svakt lys utendørs)"

#: ../src/iop/filmic.c:352
msgid "12 EV (outdoors)"
msgstr "12 EV (utendørs)"

#: ../src/iop/filmic.c:360
msgid "13 EV (bright outdoors)"
msgstr "13 EV (skarpt lys utendørs)"

#: ../src/iop/filmic.c:368
msgid "14 EV (backlighting)"
msgstr "14 EV (motlys)"

#: ../src/iop/filmic.c:376
msgid "15 EV (sunset)"
msgstr "15 EV (solnedgang)"

#: ../src/iop/filmic.c:384
msgid "16 EV (HDR)"
msgstr "16 EV (HDR)"

#: ../src/iop/filmic.c:392
msgid "18 EV (HDR++)"
msgstr "18 EV (HDR++)"

#: ../src/iop/filmic.c:1462
msgid "read-only graph, use the parameters below to set the nodes"
msgstr ""
"grafen er kun for avlesning, bruk parameterne under for å sette knutepunkter"

#: ../src/iop/filmic.c:1471
msgid ""
"adjust to match the average luminance of the subject.\n"
"except in back-lighting situations, this should be around 18%."
msgstr ""
"juster for å matche gjennomsnittsluminans for motivet.\n"
"bortsett fra i motlys-situasjoner bør dette være rundt 18%."

#: ../src/iop/filmic.c:1483 ../src/iop/filmicrgb.c:4391
msgid ""
"number of stops between middle gray and pure white.\n"
"this is a reading a lightmeter would give you on the scene.\n"
"adjust so highlights clipping is avoided"
msgstr ""
"antallet blendertrinn mellom middels grå og ren hvit\n"
"dette er avlesningen en lysmåler ville gitt på stedet.\n"
"juster slik at høylys-klipping unngås"

#: ../src/iop/filmic.c:1496 ../src/iop/filmicrgb.c:4402
msgid ""
"number of stops between middle gray and pure black.\n"
"this is a reading a lightmeter would give you on the scene.\n"
"increase to get more contrast.\n"
"decrease to recover more details in low-lights."
msgstr ""
"antallet blendertrinn mellom middels grå og ren svart\n"
"dette er avlesningen en lysmåler ville gitt på stedet\n"
"øk verdien for å gi mer kontrast.\n"
"reduser verdien for å gjenopprette detaljer i områder med lite lys."

#: ../src/iop/filmic.c:1509
msgid ""
"increase or decrease the computed dynamic range.\n"
"useful in conjunction with \"auto tune levels\"."
msgstr ""
"utvid eller reduser den beregnede dynamiske spennvidden\n"
"dette er nyttig sammen med \"autojustering av nivåer\"."

#: ../src/iop/filmic.c:1519
msgid ""
"try to optimize the settings with some guessing.\n"
"this will fit the luminance range inside the histogram bounds.\n"
"works better for landscapes and evenly-lit images\n"
"but fails for high-keys and low-keys."
msgstr ""
"forsøk å optimalisere innstillingene med litt gjetting.\n"
"dette vil tilpasse luminans-området til grensene for histogrammet.\n"
"virker bedre for landskap og motiver med jevnt lys,\n"
"men fungerer dårlig ved svake eller skarpe lysforhold."

#: ../src/iop/filmic.c:1529 ../src/iop/filmicrgb.c:4503
msgid ""
"slope of the linear part of the curve\n"
"affects mostly the mid-tones"
msgstr ""
"stigning for lineær del av kurve\n"
"størst virkning i midt-tone-området"

#: ../src/iop/filmic.c:1536 ../src/iop/filmicrgb.c:4513
msgctxt "curve-linear-part-width"
msgid "latitude"
msgstr "lineær del"

#: ../src/iop/filmic.c:1539
msgid ""
"width of the linear domain in the middle of the curve.\n"
"increase to get more contrast at the extreme luminances.\n"
"this has no effect on mid-tones."
msgstr ""
"bredden av lineærdelen midt i kurven\n"
"juster opp for å få mer kontrast i ekstreme luminanser\n"
"ingen effekt på midt-tone-området."

#: ../src/iop/filmic.c:1546
msgid "shadows/highlights balance"
msgstr "balanse mellom skygger og høylys"

#: ../src/iop/filmic.c:1549 ../src/iop/filmicrgb.c:4525
msgid ""
"slides the latitude along the slope\n"
"to give more room to shadows or highlights.\n"
"use it if you need to protect the details\n"
"at one extremity of the histogram."
msgstr ""
"flytter lineærdelen langs kurven\n"
"for å gi mer plass til til skygger eller høylys.\n"
"brukes ved behov for å bevare detaljer\n"
"i en ende av histogrammet."

#: ../src/iop/filmic.c:1561
msgid ""
"desaturates the input of the module globally.\n"
"you need to set this value below 100%\n"
"if the chrominance preservation is enabled."
msgstr ""
"reduserer inngående metning for modulen globalt.\n"
"verdien må settes lavere enn 100%\n"
"dersom bevaring av krominans er skrudd på."

#: ../src/iop/filmic.c:1572
msgid ""
"desaturates the output of the module\n"
"specifically at extreme luminances.\n"
"decrease if shadows and/or highlights are over-saturated."
msgstr ""
"reduserer utgående metning fra modulen\n"
"for ekstreme luminans-nivåer.\n"
"reduser verdien hvis skygger og/eller høylys er overmettet."

#. Add export intent combo
#: ../src/iop/filmic.c:1583 ../src/libs/export.c:1617
#: ../src/libs/print_settings.c:2573 ../src/libs/print_settings.c:2920
#: ../src/views/darkroom.c:3148 ../src/views/lighttable.c:1353
msgid "intent"
msgstr "hensikt"

#: ../src/iop/filmic.c:1584
msgid "contrasted"
