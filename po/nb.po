msgstr "fant ISO %d"

#: ../src/iop/denoiseprofile.c:2874
#, c-format
msgid "interpolated ISO %d (ISO %d %+d EV)"
msgstr "interpolert ISO %d (ISO %d %+d EV)"

#: ../src/iop/denoiseprofile.c:2878
#, c-format
msgid "interpolated ISO %d"
msgstr "interpolert ISO %d"

#: ../src/iop/denoiseprofile.c:3614
msgid "Y0"
msgstr "Y0"

#: ../src/iop/denoiseprofile.c:3615
msgid "U0V0"
msgstr "U0V0"

#: ../src/iop/denoiseprofile.c:3653
msgid ""
"use only with a perfectly\n"
"uniform image if you want to\n"
"estimate the noise variance."
msgstr ""
"brukes kun med et helt\n"
"flatt motiv hvis du vil\n"
"estimere støy-variansen."

#: ../src/iop/denoiseprofile.c:3659
msgid "variance computed on the red channel"
msgstr "beregnet varians for rød kanal"

#: ../src/iop/denoiseprofile.c:3663
