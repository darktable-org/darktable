msgstr "tonetilpasning|kurve|visningstransform|kontrast|fargemetning|høylys"

#: ../src/iop/filmicrgb.c:341
msgid ""
"apply a view transform to prepare the scene-referred pipeline\n"
"for display on SDR screens and paper prints\n"
"while preventing clipping in non-destructive ways"
msgstr ""
"bruk en visningstransform for å forberede den\n"
"scenerefererte prosesseringskjeden for visning på SDR-skjermer\n"
"og papirprint mens klipping unngås"

#: ../src/iop/filmicrgb.c:1305
