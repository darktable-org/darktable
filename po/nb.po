#: ../src/iop/denoiseprofile.c:3681 ../src/libs/export.c:1599
#: ../src/libs/neural_restore.c:2367 ../src/libs/print_settings.c:2518
#: ../src/libs/print_settings.c:2874
msgid "profile"
msgstr "profil"

#: ../src/iop/denoiseprofile.c:3715
msgid ""
"adapt denoising according to the\n"
"white balance coefficients.\n"
"should be enabled on a first instance\n"
"for better denoising.\n"
"should be disabled if an earlier instance\n"
"has been used with a color blending mode."
msgstr ""
"tilpass støyfjerning basert på\n"
"koeffisientene for hvitbalanse.\n"
"bør aktiveres i første forekomst\n"
"for bedre støyfjerning.\n"
"bør deaktiveres hvis allerede brukt i en\n"
"tidligere forekomst med fargeblandingsmodus."

#: ../src/iop/denoiseprofile.c:3721
msgid ""
"if enabled, reduces the ISO used for denoise\n"
"by the factor of the camera's hidden exposure\n"
"bias used in HDR / highlight preservation /\n"
"dynamic range / HLG tone modes."
msgstr ""
"hvis aktivert, reduserer ISO brukt for støyreduksjon\n"
"med faktoren fra kameraets skjulte eksponerings-\n"
"kompensasjon brukt i HDR / høylysbevaring /\n"
"dynamisk område / HLG tonemodus."

#: ../src/iop/denoiseprofile.c:3726
msgid ""
"fix bugs in Anscombe transform resulting\n"
"in undersmoothing of the green channel in\n"
"wavelets mode, combined with a bad handling\n"
"of white balance coefficients, and a bug in\n"
"non-local means normalization resulting in\n"
"undersmoothing when patch size was increased.\n"
"enabling this option will change the denoising\n"
"you get. once enabled, you won't be able to\n"
"return back to old algorithm."
msgstr ""
"reparer feil i Anscombe-transformen som resulterer\n"
"i for lite utjevning i grønnkanalen i\n"
"småbølgemodus, kombinert med en dårlig håndtering\n"
"av hvitbalansekoeffisientene og en feil i den\n"
"ikkelokale gjennomsnittsnormaliseringen som fører til\n"
"for lite utjevning når lappestørrelsen økes.\n"
"Aktivering av dette alternativet vil endre støyreduksjonen\n"
"du får. når den er aktivert vil du ikke kunne gå tilbake til\n"
"den gamle algoritmen."

#: ../src/iop/denoiseprofile.c:3736
msgid "profile used for variance stabilization"
msgstr "profil brukt for stabilisering av varians"

#: ../src/iop/denoiseprofile.c:3738
msgid ""
"method used in the denoising core.\n"
"non-local means works best for `lightness' blending,\n"
"wavelets work best for `color' blending"
msgstr ""
"metode som brukes sentralt i støyreduksjonsmodulen. \n"
"ikke-lokal metode virker best for `lysstyrke'-blanding, \n"
"småbølger virker best for `farge'-blanding"

#: ../src/iop/denoiseprofile.c:3742
msgid ""
"color representation used within the algorithm.\n"
"RGB keeps the RGB channels separated,\n"
"while Y0U0V0 combine the channels to\n"
"denoise chroma and luma separately."
msgstr ""
"fargerepresentasjon brukt i algoritmen.\n"
"RGB holder RGB-kanalene separert,\n"
"mens Y0U0V0 kombinerer kanalene for å\n"
"støyredusere kroma og luma separat."

#: ../src/iop/denoiseprofile.c:3747
msgid ""
"radius of the patches to match.\n"
"increase for more sharpness on strong edges, and better denoising of smooth "
"areas.\n"
"if details are oversmoothed, reduce this value or increase the central pixel "
"weight slider."
msgstr ""
"radius for lappene som skal passe sammen.\n"
"øk for mer skarphet rundt kantene og bedre støyreduksjon i jevne områder.\n"
"hvis detaljer blir for glatte bør verdien reduseres eller glideren for "
"sentral pikselvekt økes."

#: ../src/iop/denoiseprofile.c:3753
msgid ""
"emergency use only: radius of the neighborhood to search patches in. increase "
"for better denoising performance, but watch the long runtimes! large radii "
"can be very slow. you have been warned"
msgstr ""
"kun for nødbruk: radius for områdesøk etter lapper. øk verdien for bedre "
"støyfjerning, men vær forberedt på lang behandlingstid! det kan ta mye tid å "
"behandle store områder. du er advart"

#: ../src/iop/denoiseprofile.c:3759
msgid ""
"scattering of the neighborhood to search patches in.\n"
"increase for better coarse-grain noise reduction.\n"
"does not affect execution time."
msgstr ""
"spredning av nærliggende områder punkt for søk etter lapper.\n"
"øk verdien for bedre reduksjon av grovkornet støy.\n"
"påvirker ikke responstid."

#: ../src/iop/denoiseprofile.c:3763
msgid ""
"increase the weight of the central pixel\n"
"of the patch in the patch comparison.\n"
"useful to recover details when patch size\n"
"is quite big."
msgstr ""
"øk vektingen av sentrale piksler\n"
"i lappen i sammenligningen av lappene.\n"
"nyttig for å hente tilbake detaljer når lapp-størrelsen\n"
"er ganske stor."

#: ../src/iop/denoiseprofile.c:3767
msgid "finetune denoising strength"
msgstr "finjuster styrken av støyreduksjonen"

#: ../src/iop/denoiseprofile.c:3769
msgid ""
"controls the way parameters are autoset.\n"
"increase if shadows are not denoised enough\n"
"or if chroma noise remains.\n"
"this can happen if your image is underexposed."
msgstr ""
"styrer måten parametre settes automatisk\n"
"øk verdien hvis støyreduksjon i skygger ikke er god nok\n"
"eller hvis fargestøy ikke blir borte.\n"
"dette kan skje med undereksponerte motiver."

#: ../src/iop/denoiseprofile.c:3774
msgid ""
"finetune shadows denoising.\n"
"decrease to denoise more aggressively\n"
"dark areas of the image."
msgstr ""
"finjustering av støyredusering i skygger.\n"
"reduser verdien for mer aggressiv støyreduksjon\n"
"i mørke områder av bildet."

#: ../src/iop/denoiseprofile.c:3778
msgid ""
"correct color cast in shadows.\n"
"decrease if shadows are too purple.\n"
"increase if shadows are too green."
msgstr ""
"korrigering av fargestikk i skygger.\n"
"reduser verdien hvis skyggene er for lilla.\n"
"øk hvis skyggene er for grønne."

#: ../src/iop/denoiseprofile.c:3782
msgid ""
"upgrade the variance stabilizing algorithm.\n"
"new algorithm extends the current one.\n"
"it is more flexible but could give small\n"
"differences in the images already processed."
msgstr ""
"oppgrader algoritmen for varianse-stabilisering.\n"
"den nye algoritmen utvider den gamle.\n"
"den er mer fleksibel, men kan gi små\n"
"forskjeller i bildene som allerede er prosessert."

#: ../src/iop/diffuse.c:124
msgid "diffuse or sharpen"
msgstr "diffusering eller skjerpe"

#: ../src/iop/diffuse.c:129
msgid ""
"diffusion|deconvolution|blur|sharpening|bloom|clarity|dehaze|denoise|inpaint|"
"watercolor"
msgstr ""
"diffusering|dekonvolusjon|uskarphet|skjerping|glød|fjerne dis|støyreduksjon|"
"innmaling|vannfarge"

#: ../src/iop/diffuse.c:136
msgid ""
"simulate directional diffusion of light with heat transfer model\n"
"to apply an iterative edge-oriented blur, inpaint damaged parts\n"
"of the image, or to remove blur with blind deconvolution"
msgstr ""
"etterlign retningsbestemt diffusering av lys med en varmeoverføringsmodell\n"
"for å tilføre en gjentakende kantorientert uskarphet, male inn skadede deler\n"
"av bildet eller fjerne tilsløring med blind dekonvolusjon"

#. deblurring presets
