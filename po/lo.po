msgctxt "section"
msgid "camera control"
msgstr "ການຄວບຄຸມກ້ອງ"

#: ../src/libs/camera.c:444 ../src/libs/histogram.c:779
msgid "modes"
msgstr "ໂໝດ"

#: ../src/libs/camera.c:445
msgid "timer (s)"
msgstr "ເວລາຕັ້ງຖ່າຍ (ວິນາທີ)"

#: ../src/libs/camera.c:446
msgid "count"
msgstr "ຈຳນວນ"

