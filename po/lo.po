msgstr "ຖາມກ່ອນລຶບແທັກ"

#: ../build/bin/preferences_gen.h:4001
msgid "ask before deleting a style"
msgstr "ຖາມກ່ອນລຶບສະໄຕລ໌ (Style)"

#: ../build/bin/preferences_gen.h:4017
