#: ../build/bin/preferences_gen.h:4042
msgid "will ask for confirmation before exporting files in overwrite mode"
msgstr "ຈະຖາມເພື່ອຢືນຢັນກ່ອນສົ່ງອອກໄຟລ໌ຫາກມີການຂຽນທັບ."

#: ../build/bin/preferences_gen.h:4048 ../src/libs/tools/viewswitcher.c:151
msgid "other"
msgstr "ອື່ນໆ"

#: ../build/bin/preferences_gen.h:4058
msgid "password storage backend to use"
msgstr "ລະບົບເກັບລະຫັດຜ່ານທີ່ຈະໃຊ້"

#: ../build/bin/preferences_gen.h:4075
msgid "the storage backend for password storage: auto, none, libsecret, kwallet, apple_keychain, windows_credentials"
msgstr "ລະບົບສຳລັບເກັບລະຫັດຜ່ານ."

#: ../build/bin/preferences_gen.h:4084
msgid "auto login to storage server"
msgstr "ເຂົ້າສູ່ລະບົບເຊີເວີເກັບຂໍ້ມູນອັດຕະໂນມັດ"

#: ../build/bin/preferences_gen.h:4092
msgid "automatically login to the configured storage server. this requires that a password storage backend is set."
msgstr "ເຂົ້າສູ່ລະບົບອັດຕະໂນມັດ (ຕ້ອງມີການຕັ້ງຄ່າລະບົບເກັບລະຫັດຜ່ານ)."

#: ../build/bin/preferences_gen.h:4101
