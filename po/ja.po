msgstr "子を持たないタグに「未分類」エントリを設定しません"

#: ../build/bin/preferences_gen.h:4762
msgid "tags case sensitivity"
msgstr "タグの大文字／小文字の区別"

#: ../build/bin/preferences_gen.h:4771
